{
  "name": "inertia-props-inspector",
  "displayName": "Inertia Props Inspector",
  "version": "0.0.2",
  "author": "I.K.",
  "description": "Intercept Inertia data-page attributes",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "react",
    "vite",
    "create-chrome-ext"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node src/postbuild.js",
    "preview": "vite preview",
    "fmt": "prettier --write '**/*.{tsx,ts,json,css,scss,md}'",
    "zip": "npm run build && node src/zip.js"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@types/chrome": "^0.0.313",
    "archiver": "^7.0.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.5.3",
    "terser": "^5.46.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  },
  "dependencies": {
    "preact": "^10.29.0"
  }
}
